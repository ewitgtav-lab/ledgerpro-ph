# Streamlit Cloud Secrets Configuration
# Copy this file to secrets.toml and fill in your actual values
# DO NOT commit secrets.toml to version control

# Supabase Configuration
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_KEY = "your-anon-key-here"

# Site URL for Email Redirects
# IMPORTANT: Set this to your actual Streamlit Cloud app URL in production
# Example: "https://your-app.streamlit.app"
# For local development, you can use: "http://localhost:8501"
SITE_URL = "https://your-app.streamlit.app"

# Optional: Password protection (if using password-based auth)
# password = "your-secure-password"
